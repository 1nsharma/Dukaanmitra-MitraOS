rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: stores
    // Document ID: storeId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - ownerUid: string (required, immutable)
    //   - whatsappNumber: string (required)
    //   - createdAt: timestamp (required)
    //   - totalSales: number
    //   - totalUdhaar: number
    //
    // Collection: stores/{storeId}/transactions
    // Document ID: transactionId
    // Fields:
    //   - id: string (required)
    //   - storeId: string (required)
    //   - customerId: string (optional)
    //   - type: string (required, enum: ["sale", "udhaar", "payment"])
    //   - amount: number (required)
    //   - description: string
    //   - timestamp: timestamp (required)
    //
    // Collection: stores/{storeId}/customers
    // Document ID: customerId
    // Fields:
    //   - id: string (required)
    //   - storeId: string (required)
    //   - name: string (required)
    //   - whatsappNumber: string
    //   - balance: number
    //   - lastTransactionAt: timestamp
    //
    // Collection: admins
    // Document ID: adminUid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: ["superadmin"])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isEmailVerified() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
         request.auth.token.email == "AMITSHARMA99976@gmail.com");
    }

    function isStoreOwner(storeId) {
      return isEmailVerified() && 
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerUid == request.auth.uid;
    }

    // Validation Helpers
    function isValidStore(data) {
      return data.keys().hasAll(['id', 'name', 'ownerUid', 'whatsappNumber', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.whatsappNumber is string && data.whatsappNumber.size() >= 10 && data.whatsappNumber.size() <= 15 &&
             data.ownerUid == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'storeId', 'type', 'amount', 'timestamp']) &&
             data.type in ["sale", "udhaar", "payment"] &&
             data.amount is number && data.amount > 0 &&
             data.timestamp == request.time;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'storeId', 'name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.storeId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Stores
    match /stores/{storeId} {
      allow read: if isSignedIn() && (existing().ownerUid == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidStore(incoming()) && isValidId(storeId);
      allow update: if (existing().ownerUid == request.auth.uid || isAdmin()) && 
                    isValidStore(incoming()) && 
                    incoming().ownerUid == existing().ownerUid &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'whatsappNumber', 'totalSales', 'totalUdhaar']);
      allow delete: if isAdmin();

      // Transactions
      match /transactions/{transactionId} {
        allow read: if isStoreOwner(storeId) || isAdmin();
        allow create: if isStoreOwner(storeId) && isValidTransaction(incoming()) && isValidId(transactionId);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // Customers
      match /customers/{customerId} {
        allow read: if isStoreOwner(storeId) || isAdmin();
        allow create: if isStoreOwner(storeId) && isValidCustomer(incoming()) && isValidId(customerId);
        allow update: if (isStoreOwner(storeId) || isAdmin()) && 
                      isValidCustomer(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'whatsappNumber', 'balance', 'lastTransactionAt']);
        allow delete: if isAdmin();
      }
    }

    // Mem0g Graph Memory
    match /memory_nodes/{nodeId} {
      allow read: if isAuthenticated() && (resource.data.storeId == 'demo-mode' || isStoreOwner(resource.data.storeId) || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isStoreOwner(resource.data.storeId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /memory_relations/{relId} {
      allow read: if isAuthenticated() && (resource.data.storeId == 'demo-mode' || isStoreOwner(resource.data.storeId) || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isStoreOwner(resource.data.storeId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Admins
    match /admins/{adminUid} {
      allow read: if isAuthenticated() && (request.auth.uid == adminUid || isAdmin());
      allow write: if isAdmin();
    }

    // Merchants
    match /merchants/{merchantUid} {
      allow read: if isAuthenticated() && (request.auth.uid == merchantUid || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == merchantUid || isAdmin());
    }
  }
}
